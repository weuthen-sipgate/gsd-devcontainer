# Copy this file to credentials.env and fill in your values.
# credentials.env is gitignored and loaded into the dev container at startup.

# GitHub personal access token (used by the firewall to fetch GitHub IP ranges,
# and by the gh CLI for repo operations). Needs at minimum: read:org, repo scope.
GH_TOKEN=ghp_your_github_token_here

# Anthropic API key for Claude Code
ANTHROPIC_API_KEY=sk-ant-your_api_key_here
